---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (date: Date) => date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Base title="Writing — Kacper Werema" description="Essays on engineering leadership, software architecture, quality, and living a deliberate life.">
  <section class="article">
    <div class="wrap">
      <div class="article-head">
        <p class="eyebrow">Writing</p>
        <h1>Notes on engineering, leadership &amp; life</h1>
        <p class="article-meta">Also published on <a href="https://kacperwerema.substack.com/" target="_blank" rel="noopener">Substack</a></p>
      </div>

      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/writing/${post.id}/`} class="post-row">
              <div>
                <div class="post-title">{post.data.title}</div>
                {post.data.subtitle && <div class="post-sub">{post.data.subtitle}</div>}
              </div>
              <div class="post-date">{fmt(post.data.pubDate)}</div>
            </a>
          ))}
        </div>
      ) : (
        <div class="card">
          <h3>Essays coming soon</h3>
          <p>I'm migrating my writing here. In the meantime, read everything on
            <a href="https://kacperwerema.substack.com/" target="_blank" rel="noopener"> my Substack</a>.</p>
        </div>
      )}
    </div>
  </section>
</Base>
