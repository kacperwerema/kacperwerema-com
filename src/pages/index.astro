---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<Base>
  <!-- HERO -->
  <header class="hero">
    <div class="wrap">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="eyebrow">Fractional CTO · Technical Advisor · Head of Engineering</p>
          <h1>I turn engineering into a <em>business advantage.</em></h1>
          <p class="lede">
            15+ years leading engineering across fintech, banking and SaaS. I help founders
            and scaleups ship reliable software faster — sharper architecture, quality systems,
            and leadership that moves the numbers.
          </p>
          <div class="hero-cta">
            <a href="#contact" class="btn btn-primary">Book a strategy call</a>
            <a href="#results" class="btn btn-ghost">See the results</a>
          </div>
        </div>
        <div class="hero-photo">
          <img src="/kacper.jpg" alt="Kacper Werema" width="680" height="906" />
        </div>
      </div>
    </div>
  </header>

  <hr class="divider" />

  <!-- PROOF STATS -->
  <section style="padding: 48px 0;">
    <div class="wrap">
      <div class="stats-row">
        <div class="stat">
          <div class="stat-num">4mo → 6wk</div>
          <div class="stat-label">Release cycle cut at Santander Nordic</div>
        </div>
        <div class="stat">
          <div class="stat-num">0 → 50k+</div>
          <div class="stat-label">Businesses scaled on one platform</div>
        </div>
        <div class="stat">
          <div class="stat-num">£5M</div>
          <div class="stat-label">Grant secured via architecture transformation</div>
        </div>
        <div class="stat">
          <div class="stat-num">2M/day</div>
          <div class="stat-label">Users served at 99.9% availability</div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- SERVICES -->
  <section id="services">
    <div class="wrap">
      <p class="section-label">How I help</p>
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:48px;align-items:start;">
        <div>
          <h2>Engineering leadership, on demand.</h2>
          <p class="mt-sm" style="font-size:1rem;">You don't always need a full-time CTO. You need the right decisions made at the right time — and someone accountable for the outcome.</p>
        </div>
        <div class="cards">
          <div class="card">
            <div class="card-tag">Strategy</div>
            <h3>Technical Strategy & Architecture</h3>
            <p>Roadmaps and system design that match your stage. From monolith-to-microservices to multi-tenant SaaS.</p>
          </div>
          <div class="card">
            <div class="card-tag">Quality</div>
            <h3>Quality & Delivery Transformation</h3>
            <p>Shift-left quality, test automation and SDLC redesign. Built on my P.I.R.A.T.E.S. quality-maturity framework.</p>
          </div>
          <div class="card">
            <div class="card-tag">Leadership</div>
            <h3>Engineering Leadership</h3>
            <p>Team topologies, hiring, coaching and the operating cadence that turns engineers into a high-trust, high-output team.</p>
          </div>
          <div class="card">
            <div class="card-tag">AI</div>
            <h3>AI & Automation Leverage</h3>
            <p>Where AI and agentic systems create real ROI. Practical adoption that finances itself — not science projects.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- RESULTS -->
  <section id="results">
    <div class="wrap">
      <p class="section-label">Selected work</p>
      <div class="work-grid">
        <div class="work-card">
          <h3>Santander Nordic</h3>
          <div class="role">Technical Advisor — Quality & Platform</div>
          <p>Core designer of the quality process that cut release cycles from 4 months to 6 weeks across 6 teams / 28 engineers. Built the E2E, load and contract automation foundation.</p>
        </div>
        <div class="work-card">
          <h3>Swoop Funding</h3>
          <div class="role">Technical Advisor — Leadership & Architecture</div>
          <p>Scaled from 0 to 50k+ businesses. Re-architected monolith → microservices and enabled the multi-tenant migration that secured a £5M grant.</p>
        </div>
        <div class="work-card">
          <h3>Staff Bit</h3>
          <div class="role">CTO & Co-founder (Exit)</div>
          <p>Built from zero to exit with P&L ownership. Led 20+ engineers, ran enterprise transformations for clients including Santander and Zara.</p>
        </div>
        <div class="work-card">
          <h3>DMSales</h3>
          <div class="role">Fractional CTO</div>
          <p>Technical strategy and ROI advisory for a bootstrapped ad-tech competing with Apollo.io. Shipped an AI extension profitable from day zero.</p>
        </div>
      </div>
      <p class="center mt-lg"><a href="/about" class="btn btn-ghost">Full background →</a></p>
    </div>
  </section>

  <!-- WRITING PREVIEW -->
  {posts.length > 0 && (
    <>
      <hr class="divider" />
      <section id="writing">
        <div class="wrap">
          <p class="section-label">Writing</p>
          <div style="display:grid;grid-template-columns:1fr 2fr;gap:48px;align-items:start;">
            <h2>Notes on engineering, leadership & life.</h2>
            <div class="post-list">
              {posts.map((post) => (
                <a href={`/writing/${post.id}/`} class="post-row">
                  <div>
                    <div class="post-title">{post.data.title}</div>
                    {post.data.subtitle && <div class="post-sub">{post.data.subtitle}</div>}
                  </div>
                  <div class="post-date">{fmt(post.data.pubDate)}</div>
                </a>
              ))}
              <a href="/writing" class="post-row" style="border-bottom:none;padding-bottom:0;">
                <div class="post-title" style="color:var(--accent);">All writing →</div>
              </a>
            </div>
          </div>
        </div>
      </section>
    </>
  )}

  <hr class="divider" />

  <!-- CONTACT -->
  <section id="contact">
    <div class="wrap">
      <div class="cta-band">
        <h2>Let's talk about your engineering org</h2>
        <p>Whether you're scaling a team, fixing delivery, or deciding where AI actually fits — a 30-minute call will tell us if I can help.</p>
        <div class="hero-cta" style="justify-content:center;">
          <a href="https://strategyexperts.tech/" target="_blank" rel="noopener" class="btn btn-primary">Book a strategy call</a>
          <a href="mailto:kacper.werema@gmail.com" class="btn btn-ghost">Email me</a>
        </div>
      </div>
    </div>
  </section>
</Base>
